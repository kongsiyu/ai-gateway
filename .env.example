# Server
PORT=3000
NODE_ENV=development

# Master API key for admin operations
MASTER_API_KEY=your-master-key-here

# Provider API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=...
MISTRAL_API_KEY=...

# Database (for API key management and usage tracking)
DATABASE_URL=postgresql://user:password@localhost:5432/ai_gateway

# Redis (for rate limiting)
REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info
